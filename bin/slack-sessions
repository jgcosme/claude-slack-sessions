#!/bin/bash
# Lazy bootstrap wrapper. Ensures bin/slack-sessions-cli is installed
# (downloads from GH Releases on first run, falls back to cargo build) then
# execs it with whatever args followed. Used by slash-command markdown so
# plugin install is a no-op until the first command, when binaries are
# fetched on demand. Mirrors the obsidian-memory bin/run convention.

set -eu
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CLI="$PLUGIN_ROOT/bin/slack-sessions-cli"

if [ ! -x "$CLI" ]; then
  if ! bash "$SCRIPT_DIR/install.sh" >&2; then
    echo "[slack-sessions] binary install failed; see message above" >&2
    exit 1
  fi
fi

exec "$CLI" "$@"
